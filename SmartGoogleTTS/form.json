{
    "elements": [
        {
            "type": "PasswordTextBox",
            "name": "ApiKey",
            "caption": "Google Cloud API Key"
        },
        {
            "type": "Select",
            "name": "VoiceName",
            "caption": "Sprache / Stimme",
            "options": [
                {"label": "Deutsch (Wavenet A, Weiblich)", "value": "de-DE-Wavenet-A"},
                {"label": "Deutsch (Wavenet B, Männlich)", "value": "de-DE-Wavenet-B"},
                {"label": "Deutsch (Wavenet C, Weiblich)", "value": "de-DE-Wavenet-C"},
                {"label": "Deutsch (Wavenet D, Männlich)", "value": "de-DE-Wavenet-D"},
                {"label": "Deutsch (Wavenet E, Männlich)", "value": "de-DE-Wavenet-E"},
                {"label": "Deutsch (Wavenet F, Weiblich)", "value": "de-DE-Wavenet-F"},
                {"label": "Deutsch (Standard A, Weiblich)", "value": "de-DE-Standard-A"},
                {"label": "Deutsch (Standard B, Männlich)", "value": "de-DE-Standard-B"},
                {"label": "English (Wavenet A, Female)", "value": "en-US-Wavenet-A"},
                {"label": "English (Wavenet B, Male)", "value": "en-US-Wavenet-B"},
                {"label": "English (Wavenet C, Female)", "value": "en-US-Wavenet-C"},
                {"label": "English (Wavenet D, Male)", "value": "en-US-Wavenet-D"}
            ]
        },
        {
            "type": "List",
            "name": "SonosInstances",
            "caption": "Sonos Systeme",
            "add": true,
            "delete": true,
            "changeOrder": true,
            "columns": [
                {
                    "caption": "Instanz",
                    "name": "InstanceID",
                    "width": "auto",
                    "add": 0,
                    "edit": {
                        "type": "SelectInstance"
                    }
                },
                {
                    "caption": "Lautstärke",
                    "name": "Volume",
                    "width": "200px",
                    "add": "+0",
                    "edit": {
                        "type": "ValidationTextBox"
                    }
                }
            ]
        },
        {
            "type": "ValidationTextBox",
            "name": "SymconBaseURL",
            "caption": "IP-Symcon Base URL (z.B. http://192.168.1.100:3777)",
            "validate": "^https?://.+"
        },
        {
            "type": "NumberSpinner",
            "name": "SpeakingRate",
            "caption": "Sprechgeschwindigkeit (0.25 bis 4.0, Standard: 1.0)",
            "digits": 2,
            "minimum": 0.25,
            "maximum": 4.0
        },
        {
            "type": "NumberSpinner",
            "name": "Pitch",
            "caption": "Tonhöhe (Stimme hoch/tief, -20.0 bis 20.0, Standard: 0.0)",
            "digits": 1,
            "minimum": -20.0,
            "maximum": 20.0
        }
    ],
    "actions": [
        {
            "type": "ValidationTextBox",
            "name": "TestText",
            "caption": "Test Text",
            "value": "Die Waschmaschine ist fertig!"
        },
        {
            "type": "Button",
            "caption": "Test Sprachausgabe",
            "onClick": "SGTTS_PlayMessage($id, $TestText);"
        },
        {
            "type": "Button",
            "caption": "Cache komplett leeren",
            "onClick": "SGTTS_ClearCache($id);"
        }
    ]
}
