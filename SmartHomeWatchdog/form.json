{
    "elements": [
        {
            "type": "SelectInstance",
            "name": "VisuInstanceID",
            "caption": "Tile Visu Instanz (Optional)"
        },
        {
            "type": "SelectInstance",
            "name": "TTSInstanceID",
            "caption": "GoogleSonosTTS Instanz (Optional)"
        },
        {
            "type": "List",
            "name": "Rules",
            "caption": "Überwachungs-Regeln",
            "add": true,
            "delete": true,
            "columns": [
                {
                    "caption": "Aktiv",
                    "name": "Active",
                    "width": "50px",
                    "add": true,
                    "edit": {
                        "type": "CheckBox"
                    }
                },
                {
                    "caption": "Name / Titel",
                    "name": "Name",
                    "width": "150px",
                    "add": "Neuer Alarm",
                    "edit": {
                        "type": "ValidationTextBox"
                    }
                },
                {
                    "caption": "Überwachte Variable",
                    "name": "VariableID",
                    "width": "250px",
                    "add": 0,
                    "edit": {
                        "type": "SelectVariable"
                    }
                },
                {
                    "caption": "Bedingung",
                    "name": "Condition",
                    "width": "120px",
                    "add": "==",
                    "edit": {
                        "type": "Select",
                        "options": [
                            {"caption": "Gleich (==)", "value": "=="},
                            {"caption": "Ungleich (!=)", "value": "!="},
                            {"caption": "Größer als (>)", "value": ">"},
                            {"caption": "Kleiner als (<)", "value": "<"}
                        ]
                    }
                },
                {
                    "caption": "Wert",
                    "name": "TargetValue",
                    "width": "100px",
                    "add": "true",
                    "edit": {
                        "type": "ValidationTextBox"
                    }
                },
                {
                    "caption": "Verzögerung (Min)",
                    "name": "DelayMinutes",
                    "width": "100px",
                    "add": 0,
                    "edit": {
                        "type": "NumberSpinner"
                    }
                },
                {
                    "caption": "Visu Meldung",
                    "name": "EnableVisu",
                    "width": "80px",
                    "add": true,
                    "edit": {
                        "type": "CheckBox"
                    }
                },
                {
                    "caption": "Sonos TTS",
                    "name": "EnableTTS",
                    "width": "80px",
                    "add": true,
                    "edit": {
                        "type": "CheckBox"
                    }
                },
                {
                    "caption": "TTS Ansagetext",
                    "name": "TTSText",
                    "width": "auto",
                    "add": "Alarm ausgelöst!",
                    "edit": {
                        "type": "ValidationTextBox"
                    }
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Teste erste aktive Regel",
            "onClick": "SHW_TestNotification($id);"
        }
    ]
}
