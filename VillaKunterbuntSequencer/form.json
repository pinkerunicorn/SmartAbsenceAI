{
    "elements": [
        {
            "type": "Label",
            "caption": "Eigenständiger Sequencer, der auf eine Variable lauscht."
        },
        {
            "type": "SelectVariable",
            "name": "TriggerVariable",
            "caption": "Auslöser-Variable (z.B. Haus Modus)"
        },
        {
            "type": "ValidationTextBox",
            "name": "TriggerValue",
            "caption": "Auslöser-Wert (z.B. 4 für Heimkino)"
        },
        {
            "type": "List",
            "name": "Sequences",
            "caption": "Sequenz (Ablauf)",
            "add": true,
            "delete": true,
            "columns": [
                {
                    "caption": "Aktion",
                    "name": "ActionType",
                    "width": "200px",
                    "add": 0,
                    "edit": {
                        "type": "Select",
                        "options": [
                            {"caption": "Skript / Ablaufplan ausführen", "value": 0},
                            {"caption": "Gerät/Variable schalten", "value": 1},
                            {"caption": "Wake on LAN (WOL)", "value": 2}
                        ]
                    }
                },
                {
                    "caption": "Ziel Instanz / Skript",
                    "name": "TargetID",
                    "width": "250px",
                    "add": 0,
                    "edit": {
                        "type": "SelectObject"
                    }
                },
                {
                    "caption": "Wert (Nur für Schalten)",
                    "name": "Value",
                    "width": "150px",
                    "add": "",
                    "edit": {
                        "type": "ValidationTextBox"
                    }
                },
                {
                    "caption": "Verzögerung (Sek)",
                    "name": "Delay",
                    "width": "100px",
                    "add": 0,
                    "edit": {
                        "type": "NumberSpinner",
                        "minimum": 0,
                        "maximum": 3600
                    }
                }
            ]
        }
    ]
