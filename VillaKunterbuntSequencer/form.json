{
    "elements": [
        {
            "type": "Label",
            "caption": "Makro-Baustein: Definiert eine Liste von Aktionen, die vom Controller oder manuell ausgelöst werden können."
        },
        {
            "type": "List",
            "name": "Sequences",
            "caption": "Ablauf (wird von oben nach unten abgearbeitet)",
            "add": true,
            "delete": true,
            "columns": [
                {
                    "caption": "Aktion",
                    "name": "ActionType",
                    "width": "200px",
                    "add": 0,
                    "edit": {
                        "type": "Select",
                        "options": [
                            {"caption": "Skript / Ablaufplan ausführen", "value": 0},
                            {"caption": "Gerät/Variable schalten", "value": 1},
                            {"caption": "Wake on LAN (WOL)", "value": 2}
                        ]
                    }
                },
                {
                    "caption": "Ziel Instanz / Skript",
                    "name": "TargetID",
                    "width": "250px",
                    "add": 0,
                    "edit": {
                        "type": "SelectObject"
                    }
                },
                {
                    "caption": "Wert (Nur für Schalten)",
                    "name": "Value",
                    "width": "150px",
                    "add": "",
                    "edit": {
                        "type": "ValidationTextBox"
                    }
                },
                {
                    "caption": "Verzögerung (Sek)",
                    "name": "Delay",
                    "width": "100px",
                    "add": 0,
                    "edit": {
                        "type": "NumberSpinner",
                        "minimum": 0,
                        "maximum": 3600
                    }
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Ablauf jetzt auslösen (Test)",
            "onClick": "VKSQ_RunSequence($id);"
        }
    ]
}
