{
    "elements": [
        {
            "type": "Label",
            "caption": "Orchestrierung der SmartAbsence-Submodule"
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "SelectInstance",
                    "name": "HeatingInstance",
                    "caption": "Heating (Thermostat) Instanz"
                },
                {
                    "type": "CheckBox",
                    "name": "EnableHeating",
                    "caption": "Aktiv"
                }
            ]
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "SelectInstance",
                    "name": "SecurityInstance",
                    "caption": "Security (Türen/Fenster) Instanz"
                },
                {
                    "type": "CheckBox",
                    "name": "EnableSecurity",
                    "caption": "Aktiv"
                }
            ]
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "SelectInstance",
                    "name": "LightingInstance",
                    "caption": "Lighting (Sub-Modul)"
                },
                {
                    "type": "CheckBox",
                    "name": "EnableLighting",
                    "caption": "Aktiv"
                }
            ]
        },
        {
            "type": "Label",
            "caption": "Sonos Integration (Putzmodus etc.)"
        },
        {
            "type": "CheckBox",
            "name": "EnableSonos",
            "caption": "Sonos Steuerung aktivieren"
        },
        {
            "type": "List",
            "name": "SonosInstances",
            "caption": "Sonos Instanzen",
            "add": true,
            "delete": true,
            "columns": [
                {
                    "caption": "Instanz",
                    "name": "InstanceID",
                    "width": "600px",
                    "add": 0,
                    "edit": {
                        "type": "SelectInstance"
                    }
                }
            ]
        },
        {
            "type": "Label",
            "caption": "Urlaubs-Automatik"
        },
        {
            "type": "ValidationTextBox",
            "name": "CalendarURL",
            "caption": "Google Kalender (iCal) URL (privater Link)"
        },
        {
            "type": "Label",
            "caption": "Benachrichtigungen"
        },
        {
            "type": "SelectInstance",
            "name": "WebFrontInstance",
            "caption": "WebFront / Visu Instanz (für Push)"
        },
        {
            "type": "CheckBox",
            "name": "PushNotifyWindows",
            "caption": "Warnung bei offenen Fenstern (Push)"
        },
        {
            "type": "CheckBox",
            "name": "PushNotifyLights",
            "caption": "Warnung bei aktiven Lichtern (Push)"
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Manueller Kalender Sync",
            "onClick": "SAC_CheckCalendar($id);"
        }
    ]
}
