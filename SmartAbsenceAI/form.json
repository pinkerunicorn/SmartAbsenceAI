            "add": true,
            "delete": true,
            "columns": [
                {
                    "caption": "Variable",
                    "name": "VariableID",
                    "width": "auto",
                    "add": 0,
                    "edit": {
                        "type": "SelectVariable"
                    }
                }
            ]
        },
        {
            "type": "Label",
            "label": "Türen verriegeln"
        },
        {
            "type": "List",
            "name": "DoorVariables",
            "caption": "Türschlösser (Status Variablen)",
            "add": true,
            "delete": true,
            "columns": [
                {
                    "caption": "Variable",
                    "name": "VariableID",
                    "width": "auto",
                    "add": 0,
                    "edit": {
                        "type": "SelectVariable"
                    }
                }
            ]
        },
        {
            "type": "Label",
            "label": "Sicherheitsprüfung vor Abwesenheit"
        },
        {
            "type": "List",
            "name": "SecurityVariables",
            "caption": "Fenster/Türen (Müssen diesen Zustand haben)",
            "rowCount": 15,
            "add": true,
            "delete": true,
            "columns": [
                {
                    "caption": "Variable",
                    "name": "VariableID",
                    "width": "auto",
                    "add": 0,
                    "edit": {
                        "type": "SelectVariable"
                    }
                },
                {
                    "caption": "Name",
                    "name": "Name",
                    "width": "auto",
                    "add": "",
                    "edit": {
                        "type": "ValidationTextBox"
                    }
                },
                {
                    "caption": "Soll-Wert ('Geschlossen', z.B. 0 oder false)",
                    "name": "ClosedValue",
                    "width": "auto",
                    "add": "0",
                    "edit": {
                        "type": "ValidationTextBox"
                    }
                }
            ]
        },
        {
            "type": "Label",
            "label": "Licht-Simulation (KI-basiert)"
        },
        {
            "type": "List",
            "name": "LightVariables",
            "caption": "Zu simulierende Lampen (Ein/Aus oder Dimmer)",
            "rowCount": 15,
            "add": true,
            "delete": true,
            "columns": [
                {
                    "caption": "Variable",
                    "name": "VariableID",
                    "width": "auto",
                    "add": 0,
                    "edit": {
                        "type": "SelectVariable"
                    }
                },
                {
                    "caption": "Name / Raum (für die KI)",
                    "name": "Name",
                    "width": "auto",
                    "add": "",
                    "edit": {
                        "type": "ValidationTextBox"
                    }
                }
            ]
        },
        {
            "type": "Label",
            "label": "Push-Benachrichtigungen (WebFront / App)"
        },
        {
            "type": "SelectInstance",
            "name": "WebFrontInstance",
            "caption": "WebFront Configurator Instanz"
        },
        {
            "type": "CheckBox",
            "name": "PushNotifyWindows",
            "caption": "Beim Verlassen: Push senden, wenn Fenster/Türen offen sind"
        },
        {
            "type": "CheckBox",
            "name": "PushNotifyLights",
            "caption": "Beim Verlassen: Push senden, wenn Lichter noch brennen"
        }
