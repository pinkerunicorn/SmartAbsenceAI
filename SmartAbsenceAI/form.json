{
    "elements": [
        {
            "type": "Label",
            "caption": "Orchestrierung der SmartAbsence-Submodule"
        },
        {
            "type": "List",
            "name": "HouseModes",
            "caption": "Haus-Modi (Matrix & Zuweisungen)",
            "add": true,
            "delete": true,
            "columns": [
                {
                    "caption": "ID",
                    "name": "ModeID",
                    "width": "60px",
                    "add": 0,
                    "edit": {
                        "type": "NumberSpinner"
                    }
                },
                {
                    "caption": "Modus Name",
                    "name": "ModeName",
                    "width": "150px",
                    "add": "Neuer Modus",
                    "edit": {
                        "type": "ValidationTextBox"
                    }
                },
                {
                    "caption": "Icon",
                    "name": "Icon",
                    "width": "100px",
                    "add": "",
                    "edit": {
                        "type": "SelectIcon"
                    }
                },
                {
                    "caption": "Farbe",
                    "name": "Color",
                    "width": "80px",
                    "add": -1,
                    "edit": {
                        "type": "SelectColor"
                    }
                },
                {
                    "caption": "Sequencer (Optional)",
                    "name": "SequencerInstance",
                    "width": "200px",
                    "add": 0,
                    "edit": {
                        "type": "SelectInstance"
                    }
                },
                {
                    "caption": "Heizung",
                    "name": "NotifyHeating",
                    "width": "70px",
                    "add": true,
                    "edit": {
                        "type": "CheckBox"
                    }
                },
                {
                    "caption": "Licht",
                    "name": "NotifyLighting",
                    "width": "70px",
                    "add": true,
                    "edit": {
                        "type": "CheckBox"
                    }
                },
                {
                    "caption": "Sicherheit",
                    "name": "NotifySecurity",
                    "width": "70px",
                    "add": true,
                    "edit": {
                        "type": "CheckBox"
                    }
                },
                {
                    "caption": "Sonos",
                    "name": "NotifySonos",
                    "width": "70px",
                    "add": true,
                    "edit": {
                        "type": "CheckBox"
                    }
                }
            ]
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "SelectInstance",
                    "name": "HeatingInstance",
                    "caption": "Heating (Thermostat) Instanz"
                },
                {
                    "type": "CheckBox",
                    "name": "EnableHeating",
                    "caption": "Aktiv"
                }
            ]
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "SelectInstance",
                    "name": "SecurityInstance",
                    "caption": "Security (Türen/Fenster) Instanz"
                },
                {
                    "type": "CheckBox",
                    "name": "EnableSecurity",
                    "caption": "Aktiv"
                }
            ]
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "SelectInstance",
                    "name": "LightingInstance",
                    "caption": "Lighting (Sub-Modul)"
                },
                {
                    "type": "CheckBox",
                    "name": "EnableLighting",
                    "caption": "Aktiv"
                }
            ]
        },
        {
            "type": "Label",
            "caption": "Sonos Integration (Putzmodus etc.)"
        },
        {
            "type": "CheckBox",
            "name": "EnableSonos",
            "caption": "Sonos Steuerung aktivieren"
        },
        {
            "type": "List",
            "name": "SonosInstances",
            "caption": "Sonos Instanzen",
            "add": true,
            "delete": true,
            "columns": [
                {
                    "caption": "Instanz",
                    "name": "InstanceID",
                    "width": "600px",
                    "add": 0,
                    "edit": {
                        "type": "SelectInstance"
                    }
                }
            ]
        },
        {
            "type": "Label",
            "caption": "Urlaubs-Automatik"
        },
        {
            "type": "ValidationTextBox",
            "name": "CalendarURL",
            "caption": "Google Kalender (iCal) URL (privater Link)"
        },
        {
            "type": "Label",
            "caption": "Benachrichtigungen"
        },
        {
            "type": "SelectInstance",
            "name": "WebFrontInstance",
            "caption": "WebFront / Visu Instanz (für Push)"
        },
        {
            "type": "CheckBox",
            "name": "PushNotifyWindows",
            "caption": "Warnung bei offenen Fenstern (Push)"
        },
        {
            "type": "CheckBox",
            "name": "PushNotifyLights",
            "caption": "Warnung bei aktiven Lichtern (Push)"
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Manueller Kalender Sync",
            "onClick": "SAC_CheckCalendar($id);"
        }
    ]
}
