{
    "elements": [
        {
            "type": "Label",
            "caption": "Orchestrierung der SmartAbsence-Submodule"
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "SelectInstance",
                    "name": "HeatingInstance",
                    "caption": "Heating (Thermostat) Instanz"
                },
                {
                    "type": "CheckBox",
                    "name": "EnableHeating",
                    "caption": "Aktiv"
                }
            ]
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "SelectInstance",
                    "name": "SecurityInstance",
                    "caption": "Security (Türen/Fenster) Instanz"
                },
                {
                    "type": "CheckBox",
                    "name": "EnableSecurity",
                    "caption": "Aktiv"
                }
            ]
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "SelectInstance",
                    "name": "LightingInstance",
                    "caption": "Lighting (KI Licht) Instanz"
                },
                {
                    "type": "CheckBox",
                    "name": "EnableLighting",
                    "caption": "Aktiv"
                }
            ]
        },
        {
            "type": "Label",
            "caption": "Benachrichtigungen"
        },
        {
            "type": "SelectInstance",
            "name": "WebFrontInstance",
            "caption": "WebFront / Visu Instanz (für Push)"
        },
        {
            "type": "CheckBox",
            "name": "PushNotifyWindows",
            "caption": "Warnung bei offenen Fenstern (Push)"
        },
        {
            "type": "CheckBox",
            "name": "PushNotifyLights",
            "caption": "Warnung bei aktiven Lichtern (Push)"
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Abwesenheit AKTIVIEREN",
            "onClick": "RequestAction(IPS_GetObjectIDByIdent('AbsenceStatus', $id), true);"
        },
        {
            "type": "Button",
            "caption": "Abwesenheit DEAKTIVIEREN",
            "onClick": "RequestAction(IPS_GetObjectIDByIdent('AbsenceStatus', $id), false);"
        }
    ]
}
